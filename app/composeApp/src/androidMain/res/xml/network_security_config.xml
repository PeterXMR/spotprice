        <domain includeSubdomains="false">api.coingecko.com</domain>
        <pin-set expiration="2026-09-26">
            <!-- leaf SPKI (primary pin) -->
            <pin digest="SHA-256">Mt5g5IYSNNUwjs6dOdWULwrc5T9JazZ3oiBArjectPQ=</pin>
            <!-- issuing-intermediate SPKI (backup pin) -->
            <pin digest="SHA-256">kIdp6NNEd8wsugYyyIYFsi1ylMCED3hZbSR8ZFsa/A4=</pin>
