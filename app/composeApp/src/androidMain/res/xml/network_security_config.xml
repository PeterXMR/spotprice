<?xml version="1.0" encoding="utf-8"?>
<!--
  Network security configuration for SatsPrice (Android).

  Strategy: pin the leaf SPKI AS A PRIMARY pin plus the issuing intermediate CA
  SPKI as a BACKUP pin, per host. Both pins must be present for a chain to be
  accepted, but only one needs to match the served chain, so the app keeps
  working if the operator rotates the leaf inside the same intermediate (the
  common case), and only breaks if the upstream rotates *both* the leaf and the
  intermediate before we ship a new APK.

  Each <pin-set> carries an `expiration` date set slightly BEFORE the leaf's
  notAfter. After that date Android *silently disables pinning for the host*
  (falling back to platform CA trust). That is the safety valve: this app is
  shipped via GitHub Releases sideload + F-Droid, not Play autoupdate, so a
  hard pin failure with no override could brick the price view for weeks for
  users who don't update promptly. Fail-open after the rotation window is the
  correct trade-off for a public, no-PII price viewer.

  The `expiration` and `<pin>` values below are refreshed automatically by
  scripts/rotate_tls_pins.py (run daily from .github/workflows/pin-rotation.yml),
  which re-fetches each host's live chain and opens a PR when it changes. The
  comments here deliberately carry NO per-cert facts (issuer, notAfter) so they
  can never drift out of sync with the pins; the current issuer + leaf notAfter
  for every host live in the auto-maintained table in docs/PIN-ROTATION.md.

  ROTATION PLAYBOOK: docs/PIN-ROTATION.md
  Pins last fetched: 2026-07-24
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Coinbase price API (api.coinbase.com).
         Current issuer + leaf notAfter: see docs/PIN-ROTATION.md. -->
    <domain-config>
        <domain includeSubdomains="false">api.coinbase.com</domain>
        <pin-set expiration="2026-10-08">
            <!-- leaf SPKI (primary pin) -->
            <pin digest="SHA-256">4yqUio7u1JfHemLrBiGbo/jcpYfIGEp7gdf/xgSbABE=</pin>
            <!-- issuing-intermediate SPKI (backup pin) -->
            <pin digest="SHA-256">kIdp6NNEd8wsugYyyIYFsi1ylMCED3hZbSR8ZFsa/A4=</pin>
        </pin-set>
    </domain-config>

    <!-- Kraken price API (api.kraken.com).
         Current issuer + leaf notAfter: see docs/PIN-ROTATION.md. -->
    <domain-config>
        <domain includeSubdomains="false">api.kraken.com</domain>
        <pin-set expiration="2026-09-23">
            <!-- leaf SPKI (primary pin) -->
            <pin digest="SHA-256">bgRJ9aEZeU9T9RdxtiHelTU4RL+r5J6jfFBcETA2a3E=</pin>
            <!-- issuing-intermediate SPKI (backup pin) -->
            <pin digest="SHA-256">kIdp6NNEd8wsugYyyIYFsi1ylMCED3hZbSR8ZFsa/A4=</pin>
        </pin-set>
    </domain-config>

    <!-- Bitstamp price API (www.bitstamp.net).
         Current issuer + leaf notAfter: see docs/PIN-ROTATION.md. -->
    <domain-config>
        <domain includeSubdomains="false">www.bitstamp.net</domain>
        <pin-set expiration="2026-11-02">
            <!-- leaf SPKI (primary pin) -->
            <pin digest="SHA-256">T8gnqF9YYK42QKSeWc8+KzbhluuwkpwylObkbzHjRDg=</pin>
            <!-- issuing-intermediate SPKI (backup pin) -->
            <pin digest="SHA-256">w9I8WrpHr1YAS0DugvLGsrI9Vm1yEkZAyllKxemXXf4=</pin>
        </pin-set>
    </domain-config>

    <!-- CoinGecko price API (api.coingecko.com).
         Current issuer + leaf notAfter: see docs/PIN-ROTATION.md. -->
