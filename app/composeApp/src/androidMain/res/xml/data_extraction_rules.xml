<?xml version="1.0" encoding="utf-8"?>
<!--
  Data-extraction rules for Android 12+ (API 31+).

  Referenced from the manifest via
  `android:dataExtractionRules="@xml/data_extraction_rules"`. On API 31+
  this file (not backup_rules.xml) is the authoritative control for what
  the OS is allowed to copy off the device in two distinct scenarios:

    <cloud-backup>   — Google Drive auto-backup ("Back up to Google One").
    <device-transfer> — device-to-device migration when the user sets up
                        a new phone with "Copy from old device".

  Both are denied here. Combined with `android:allowBackup="false"` in the
  manifest, all extraction paths are blocked. The explicit excludes below
  are defense-in-depth so the file stays restrictive even if allowBackup
  is later changed.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" path="." />
        <exclude domain="file" path="." />
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="external" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="." />
        <exclude domain="file" path="." />
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="external" path="." />
    </device-transfer>
</data-extraction-rules>
